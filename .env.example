# Gemini API key for image generation (get one at https://aistudio.google.com/apikey)
# For local dev: set in .env as VITE_GEMINI_API_KEY=your_key
# For GitHub Pages: set as repository secret VITE_GEMINI_API_KEY
# Users can also enter their key in the Settings page (stored in browser localStorage)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
