GEMINI_API_KEY=your_gemini_api_key_here
# Or use GOOGLE_API_KEY instead (both are supported):
# GOOGLE_API_KEY=your_google_api_key_here
# If your key is a Vertex API key, enable Vertex API-key mode:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_LOCATION=global

# Optional client-side fallback key (like your prototype's apiKey variable):
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

PORT=3001

# Vertex AI (use instead of API key for Vertex AI)
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1
